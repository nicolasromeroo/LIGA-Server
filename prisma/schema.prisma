generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  password      String
  name          String
  role          String         @default("USER")
  points        Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  matchResults  MatchResult[]
  mazos         Mazo[]
  packs         Pack[]
  playerCards   PlayerCard[]
  predictions   Prediction[]
  roomPlayers   RoomPlayer[]
  torneosOwned  Torneo[]       @relation("TorneoOwner")
  torneoMembers TorneoMember[]
}

model News {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  image       String?
  category    String   @default("Novedad")
  displayMode String   @default("card")
  isPublished Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  priority    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}


model Prediction {
  id        Int      @id @default(autoincrement())
  userId    Int
  matchId   Int
  torneoId  Int?
  scoreA    Int
  scoreB    Int
  status    String   @default("pending")
  pointsWon Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  match     Match    @relation(fields: [matchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  torneo    Torneo?  @relation(fields: [torneoId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, torneoId])
  @@index([userId])
  @@index([matchId])
  @@index([torneoId])
}

model Torneo {
  id          Int            @id @default(autoincrement())
  nombre      String
  descripcion String         @default("")
  codigo      String         @unique
  ownerId     Int? // null = torneo oficial de la casa
  isPublic    Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  owner       User?          @relation("TorneoOwner", fields: [ownerId], references: [id])
  members     TorneoMember[]
  predictions Prediction[]

  @@index([ownerId])
}

model TorneoMember {
  id       Int      @id @default(autoincrement())
  torneoId Int
  userId   Int
  puntos   Int      @default(0)
  aciertos Int      @default(0) // resultados exactos acertados
  joinedAt DateTime @default(now())
  torneo   Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([torneoId, userId])
  @@index([userId])
}

model Player {
  id          Int          @id @default(autoincrement())
  name        String
  team        String
  position    String
  nationality String
  club        String
  rarity      String
  rating      Int
  overall     Int
  vision      Int
  dribble     Int
  pass        Int
  attack      Int
  defense     Int
  speed       Int
  image       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  playerCards PlayerCard[]
}

model PlayerCard {
  id          Int          @id @default(autoincrement())
  playerId    Int
  userId      Int
  rarity      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  isLocked    Boolean      @default(false)
  mazoId      Int?
  mazo        Mazo?        @relation("MazoCards", fields: [mazoId], references: [id])
  player      Player       @relation(fields: [playerId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  roomPlayers RoomPlayer[]

  @@index([playerId])
  @@index([userId])
}

model Pack {
  id        Int      @id @default(autoincrement())
  type      String
  opened    Boolean  @default(false)
  userId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Mazo {
  id     Int          @id @default(autoincrement())
  nombre String
  userId Int
  user   User         @relation(fields: [userId], references: [id])
  cards  PlayerCard[] @relation("MazoCards")

  @@index([userId])
}

model Room {
  id          Int          @id @default(autoincrement())
  code        String       @unique
  hostId      String
  private     Boolean      @default(true)
  status      String       @default("waiting")
  maxPlayers  Int          @default(10)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  roomPlayers RoomPlayer[]
}

model RoomPlayer {
  id         Int         @id @default(autoincrement())
  roomId     Int
  userId     Int
  team       Int
  pickCardId Int?
  ready      Boolean     @default(false)
  joinedAt   DateTime    @default(now())
  pick       PlayerCard? @relation(fields: [pickCardId], references: [id])
  room       Room        @relation(fields: [roomId], references: [id])
  user       User        @relation(fields: [userId], references: [id])

  @@index([pickCardId])
}

model Match {
  id           Int           @id @default(autoincrement())
  roomId       String?
  teamA        String
  teamB        String
  scheduledAt  DateTime
  startedAt    DateTime?
  finishedAt   DateTime?
  result       String?
  status       String        @default("scheduled")
  externalId   String?       @unique
  matchResults MatchResult[]
  predictions  Prediction[]
}

model MatchResult {
  id        Int      @id @default(autoincrement())
  matchId   Int
  userId    Int
  pointsWon Int
  goals     Int      @default(0)
  assists   Int      @default(0)
  saves     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  match     Match    @relation(fields: [matchId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([matchId])
  @@index([userId])
}
